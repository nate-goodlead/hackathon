{
  "name": "altis-cashflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:api": ".venv/bin/python scripts/upload_server.py",
    "dev:whatsapp": "npm run start --prefix services/whatsapp",
    "dev:full": "npm run dev:api & npm run dev:whatsapp & npm run dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "data:generate": "python3 scripts/generate_raw_data.py",
    "data:parse-incoming": ".venv/bin/python scripts/parse_incoming.py",
    "data:weather": ".venv/bin/python scripts/fetch_weather.py",
    "data:ingest": "python3 scripts/ingest.py",
    "data:forecast": ".venv/bin/python scripts/forecast.py",
    "data:reset": ".venv/bin/python scripts/reset_data.py",
    "data:pipeline": "npm run data:parse-incoming && npm run data:forecast",
    "data:pipeline:synthetic": "npm run data:generate && npm run data:ingest && npm run data:forecast",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.8"
  }
}
