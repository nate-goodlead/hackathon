# Copy to .env and fill in your keys. Never commit .env to git.

# Supabase (Postgres + Storage)
# Create token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=uploads
SUPABASE_DB_PASSWORD=

ANTHROPIC_API_KEY=
# Optional alias (server reads this too — do NOT use VITE_ in frontend code)
# VITE_ANTHROPIC_API_KEY=

# WhatsApp (Baileys bridge — npm run dev:whatsapp)
WHATSAPP_PHONE=2348161565148
WHATSAPP_BRIDGE_URL=http://localhost:8001
WHATSAPP_BRIDGE_PORT=8001
